def highlight_cols(x):
    # יוצר עותק של הטבלה עם עיצוב ריק
    df_style = pd.DataFrame('', index=x.index, columns=x.columns)
    
    # רשימת העמודות להדגשה
    target_cols = ['רווח_למנה', 'סה"כ ביקוש יומי ממוצע']
    
    for col in target_cols:
        if col in x.columns:
            # צבע רקע צהוב בהיר וכתב מודגש
            df_style[col] = 'background-color: #ffffcc; font-weight: bold; border: 1px solid black'
    return df_style

# הרצה והצגת התוצאות המעוצבות
for s in sheets:
    full_report = analyze_restaurant_complete(s)
    
    print(f"\n" + "="*60)
    print(f" דוח ניתוח נתונים סופי: מסעדת {s}")
    print("="*60)
    
    # סידור עמודות
    cols_order = ['מנה', 'רווח_למנה', 'זמן_הכנה', 'סה"כ ביקוש יומי ממוצע'] + hours
    display_df = full_report[cols_order]
    
    # הפעלת העיצוב (זה יציג טבלה גרפית יפה ב-Jupyter)
    styled_df = display_df.style.apply(highlight_cols, axis=None)
    
    # ב-Jupyter פשוט כותבים את שם המשתנה בסוף כדי להציג אותו מעוצב
    display(styled_df)